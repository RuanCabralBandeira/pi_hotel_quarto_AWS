generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model TipoQuarto {
  id        Int      @id @default(autoincrement()) @map("tipo_quarto_id")
  descricao String   @map("tipo_quarto_descricao") @db.VarChar(45)
  status    Int?     @map("tipo_quarto_status")
  quartos   Quarto[]

  @@map("tipo_quarto")
}

model Quarto {
  id           Int        @id @default(autoincrement()) @map("quarto_id")
  preco        Float      @map("quarto_preco")
  numero       String?    @map("quarto_numero") @db.VarChar(45)
  status       Int        @map("quarto_status")
  tipoQuartoId Int        @map("tipo_quarto_id")
  fotos        Foto[]
  tipoQuarto   TipoQuarto @relation(fields: [tipoQuartoId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_quarto_tipo_quarto1")

  @@index([tipoQuartoId], map: "fk_quarto_tipo_quarto1_idx")
  @@map("quarto")
}

model Foto {
  foto_id       Int     @id @default(autoincrement())
  foto_bin      String? @db.MediumText
  foto_nome     String? @db.VarChar(45)
  foto_extensao String? @db.VarChar(45)
  foto_status   Int?
  quarto_id     Int
  quarto        Quarto  @relation(fields: [quarto_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fotos_quarto1")

  @@index([quarto_id], map: "fk_fotos_quarto1_idx")
  @@map("fotos")
}
